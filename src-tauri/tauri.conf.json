{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Multi AI Mate",
  "version": "0.1.0",
  "identifier": "com.zhixing.multi-ai-mate",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -- --port 5173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Multi AI Mate",
        "width": 1440,
        "height": 1000,
        "minWidth": 960,
        "minHeight": 680,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 16
        },
        "shadow": true,
        "windowEffects": {
          "effects": [
            "underWindowBackground"
          ],
          "state": "active",
          "radius": 12
        },
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
